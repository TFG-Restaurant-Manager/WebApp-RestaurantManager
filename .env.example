# Variables de entorno para RestaurantManager
# Copia este archivo como .env y rellena los valores reales.
# Las variables con prefijo VITE_ son accesibles desde el cliente (navegador).
# NUNCA subas .env al repositorio.

# URL base de la API REST del backend
VITE_API_BASE_URL=https://api.restaurantmanager.example.com

# Client ID público de PayPal (sandbox o producción)
VITE_PAYPAL_CLIENT_ID=

# Plan ID de la suscripción mensual Pro (crear en PayPal Developer → Products & Plans)
VITE_PAYPAL_PLAN_ID=
